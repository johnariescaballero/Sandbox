# --- 1. THE BASICS (Text & Spreadsheets) ---

# CSV (index=False prevents Pandas from adding a row-number column)
df.to_csv('exported_data.csv', index=False)

# Excel (Requires 'openpyxl' installed)
df.to_excel('exported_data.xlsx', sheet_name='Results', index=False)

# Plain Text (Tab-separated)
df.to_csv('exported_data.txt', sep='\t', index=False)

# --- 2. WEB & API FORMATS ---

# JSON (orient='records' is most common for web apps)
df.to_json('exported_data.json', orient='records', indent=4)

# HTML (Generates a raw <table> string for a website)
df.to_html('table.html', index=False)

# XML
df.to_xml('exported_data.xml', index=False)

# --- 3. DATABASES (SQL) ---

# Using SQLAlchemy to push to a database
engine = create_engine('sqlite:///my_database.db')
# if_exists='replace' overwrites the table; 'append' adds to it
df.to_sql('new_table_name', engine, if_exists='replace', index=False)

# --- 4. HIGH-PERFORMANCE / BIG DATA ---

# Parquet (Fastest and smallest file size for large data)
df.to_parquet('exported_data.parquet')

# Feather (Best for short-term storage between Python scripts)
df.to_feather('exported_data.feather')

# Pickle (Saves the exact Python object state)
df.to_pickle('exported_data.pkl')

# --- 5. THE UTILITY EXPORT ---

